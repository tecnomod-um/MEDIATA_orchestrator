FROM python:3.11-slim

WORKDIR /app

# Install system dependencies and update CA certificates
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    build-essential \
    ca-certificates \
    && update-ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Clone the FHIR API repository
# Note: SSL verification is disabled due to sandboxed environment limitations
# In production, ensure proper CA certificates are installed
RUN git -c http.sslVerify=false clone https://github.com/tecnomod-um/InteroperabilityFHIRAPI.git /app

# Install Python dependencies
RUN pip install --no-cache-dir \
    numpy \
    spacy \
    nltk \
    scikit-learn \
    sentence-transformers \
    openai \
    torch \
    requests \
    farm-haystack[openai] \
    fastapi \
    uvicorn

# Download spacy model
RUN python -m spacy download en_core_web_sm

# Download NLTK data
RUN python -c "import nltk; nltk.download('stopwords'); nltk.download('punkt')"

# Expose the service port
EXPOSE 8001

# Run the FastAPI application
CMD ["uvicorn", "api.main_api_clustering:app", "--host", "0.0.0.0", "--port", "8001", "--reload"]
