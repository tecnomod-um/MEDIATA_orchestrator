# MEDIATA Orchestrator Environment Variables
# Copy this file to .env and update the values as needed

# Application Configuration
PORT=8088

# MongoDB Configuration
MONGODB_URI=mongodb://mongodb:27017/mediata

# JWT Configuration
JWT_SECRET=change-this-secret-in-production-use-a-long-random-string

# Kerberos Configuration
KERBEROS_PORT=8089

# Python RDF Builder Service
PYURL=http://rdf-builder:8000
PYPORT=8000

# Python FHIR API Service
FHIRPORT=8001

# Snowstorm Configuration
SNOWSTORM_HOST_PORT=9100
SNOWSTORM_ES_HOST_PORT=9200
SNOWSTORM_IMAGE=snomedinternational/snowstorm:latest
SNOWSTORM_ES_IMAGE=docker.elastic.co/elasticsearch/elasticsearch:8.11.1
